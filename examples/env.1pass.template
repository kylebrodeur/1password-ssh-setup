# 1Password Environment Variables Template
# Place this in your project directory and customize references
# Usage: eval $(op-reference env .env.1pass)

# ===================================================================
# API Keys - UPDATE THESE WITH YOUR ACTUAL REFERENCES
# ===================================================================
# openai: "op://Private/API-Keys/openai"
# anthropic: "op://Private/API-Keys/anthropic"  
# huggingface: "op://Private/API-Keys/hf-read-token"
# github: "op://Private/GitHub/token"

OPENAI_API_KEY="op://Private/API-Keys/openai"
ANTHROPIC_API_KEY="op://Private/API-Keys/anthropic"
HUGGINGFACE_API_TOKEN="op://Private/API-Keys/huggingface"
GITHUB_TOKEN="op://Private/GitHub/token"

# ===================================================================
# SSH Keys (used by askpass script)
# ===================================================================
# Update in ~/.ssh/askpass-1password.sh OR set here and source
SSH_KEY_PASSPHRASE="op://Private/PEGASUS-SSH/password"

# ===================================================================
# Database Connections
# ===================================================================
DATABASE_URL="op://Private/Databases/production"
REDIS_URL="op://Private/Databases/redis"

# ===================================================================
# Cloud Providers
# ===================================================================
AWS_ACCESS_KEY_ID="op://Private/AWS/access-key-id"
AWS_SECRET_ACCESS_KEY="op://Private/AWS/secret-access-key"
GCP_SERVICE_ACCOUNT_KEY="op://Private/GCP/service-account"

# ===================================================================
# Miscellaneous
# ===================================================================
SLACK_BOT_TOKEN="op://Private/Slack/bot-token"
DISCORD_BOT_TOKEN="op://Private/Discord/bot-token"
